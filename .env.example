X_CLIENT_ID=your_oauth2_client_id
X_CLIENT_SECRET=your_oauth2_client_secret

# Optional read backend for tweet search, tweet lookup, user lookup, and timelines.
# When X_CLIENT_ID is unset, HERMES_TWEET_API_KEY is enough for read commands.
# When both backends are configured, set X_CLI_READ_BACKEND=hermes-tweet to prefer it.
HERMES_TWEET_API_KEY=xq_your_api_key
XQUIK_API_KEY=xq_your_api_key
XQUIK_BASE_URL=https://xquik.com
X_CLI_READ_BACKEND=hermes-tweet
