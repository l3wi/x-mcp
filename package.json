{
  "name": "@lewi/x-cli",
  "version": "0.2.2",
  "description": "MCP server and CLI for X/Twitter API v2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/l3wi/x-cli.git"
  },
  "bugs": {
    "url": "https://github.com/l3wi/x-cli/issues"
  },
  "homepage": "https://github.com/l3wi/x-cli#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "x",
    "twitter",
    "cli",
    "mcp",
    "oauth",
    "agent"
  ],
  "bin": {
    "x-cli": "./dist/index.js",
    "x-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "SKILL.md",
    "skills",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".env.example",
    "config.example.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.9.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('node:fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "incur": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
